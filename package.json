{
  "name": "zhi-flow",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:start": "supabase start",
    "db:status": "supabase status",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset --local",
    "db:clean": "supabase db reset --local --no-seed",
    "db:test": "supabase test db supabase/tests/database",
    "db:lint": "supabase db lint --local --level error",
    "test:storage-boundary": "node scripts/verify-storage-boundary.mjs",
    "test:production-startup": "node scripts/verify-production-startup.mjs",
    "test:client-boundary": "node --env-file=.env.local scripts/verify-client-boundary.mjs",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test && npm run db:test && npm run db:lint && npm run build && npm run test:production-startup && npm run test:client-boundary && npm run test:storage-boundary"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@supabase/supabase-js": "^2.100.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.25.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "server-only": "^0.0.1",
    "shadcn": "^4.13.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "postcss": "^8.5.21",
    "prettier": "^3.9.6",
    "supabase": "^2.110.0-beta.32",
    "tailwindcss": "^4.3.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  }
}
