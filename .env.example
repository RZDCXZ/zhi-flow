# 仅由服务端读取。复制为 .env.local 后替换占位值；不要提交真实密钥。
ZHI_FLOW_CHAT_BASE_URL=https://api.example.com/v1
ZHI_FLOW_CHAT_API_KEY=replace-with-your-api-key
ZHI_FLOW_CHAT_MODEL=replace-with-your-chat-model
ZHI_FLOW_CHAT_FIRST_BYTE_TIMEOUT_MS=15000
ZHI_FLOW_CHAT_IDLE_TIMEOUT_MS=30000
ZHI_FLOW_CHAT_TOTAL_TIMEOUT_MS=120000
ZHI_FLOW_CHAT_HEARTBEAT_INTERVAL_MS=10000
ZHI_FLOW_CHAT_MAX_STREAM_ATTEMPTS=3
ZHI_FLOW_DOCUMENT_MAX_FILES=10
ZHI_FLOW_DOCUMENT_MAX_FILE_BYTES=20971520
ZHI_FLOW_DOCUMENT_MAX_PDF_PAGES=200
ZHI_FLOW_DOCUMENT_MAX_PARSED_CHARACTERS=2000000
ZHI_FLOW_CONSUMER_PLACEHOLDER_MODE=success
ZHI_FLOW_SUPABASE_URL=http://127.0.0.1:54321
ZHI_FLOW_SUPABASE_SECRET_KEY=replace-with-your-server-secret-key
