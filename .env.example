# 仅由服务端读取。复制为 .env.local 后替换占位值；不要提交真实密钥。
ZHI_FLOW_CHAT_BASE_URL=https://api.example.com/v1
ZHI_FLOW_CHAT_API_KEY=replace-with-your-api-key
ZHI_FLOW_CHAT_MODEL=replace-with-your-chat-model
ZHI_FLOW_CHAT_TIMEOUT_MS=15000
ZHI_FLOW_SUPABASE_URL=http://127.0.0.1:54321
ZHI_FLOW_SUPABASE_SECRET_KEY=replace-with-your-server-secret-key
